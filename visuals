            background-position: center;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
        }

        .welcome-text {
            color: #007bff; /* Vibrant blue from screenshot */
            font-weight: 800;
            font-size: 2.5rem;
