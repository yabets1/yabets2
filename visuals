    <footer class="py-12 bg-black border-t border-white/10 text-center">
        <p class="text-gray-600 text-[10px] font-bold uppercase tracking-[0.2em]">&copy; 2026 YABETS DIGITAL SOLUTIONS.</p>
    </footer>

    <script>
        // Initialize Lucide icons
        lucide.createIcons();

        // Simple typing effect for "Our Services"
        const services = ["AI Automation", "Web Design", "Digital Marketing", "Software Development"];
        let serviceIndex = 0;
        let charIndex = 0;
        const target = document.querySelector('.typing-cursor');

        function type() {
            if (charIndex < services[serviceIndex].length) {
                target.previousSibling.textContent = services[serviceIndex].substring(0, charIndex + 1);
                charIndex++;
                setTimeout(type, 100);
            } else {
                setTimeout(erase, 2000);
            }
        }

        function erase() {
            if (charIndex > 0) {
                target.previousSibling.textContent = services[serviceIndex].substring(0, charIndex - 1);
                charIndex--;
                setTimeout(erase, 50);
            } else {
                serviceIndex = (serviceIndex + 1) % services.length;
                setTimeout(type, 500);
            }
        }

        // Add text node before cursor
        const textNode = document.createTextNode("");
        target.parentNode.insertBefore(textNode, target);
        type();
    </script>
</body>
</html>
