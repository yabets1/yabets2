        }

        .main-headline {
            font-size: 4rem;
            font-weight: 700;
            margin-bottom: 1rem;
            line-height: 1.1;
        }

        .services-headline {
            font-size: 2rem;
            font-weight: 400;
            margin-bottom: 2.5rem;
        }

        .typing-cursor {
            border-right: 2px solid #fff;
            margin-left: 5px;
            animation: blink 0.8s infinite;
        }

        @keyframes blink {
            50% { border-color: transparent; }
        }

        /* Buttons based on screenshot */
        .btn-white {
            background: #ffffff;
            color: #000000;
            padding: 0.8rem 2.5rem;
            border-radius: 50px;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .btn-grey {
            background: #333333;
            color: #ffffff;
            padding: 0.8rem 2.5rem;
            border-radius: 50px;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .btn-red {
            background: #ff0000;
            color: #ffffff;
            padding: 0.8rem 2.5rem;
            border-radius: 50px;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .btn-white:hover, .btn-grey:hover, .btn-red:hover {
            transform: scale(1.05);
            opacity: 0.9;
        }

        /* Mouse Indicator */
        .scroll-indicator {
            position: absolute;
            bottom: 30px;
            width: 30px;
            height: 50px;
            border: 2px solid #ffffff;
            border-radius: 20px;
            display: flex;
            justify-content: center;
            padding-top: 10px;
        }

        .scroll-indicator::before {
            content: '';
            width: 4px;
            height: 8px;
            background: #007bff;
            border-radius: 2px;
            animation: scroll-anim 2s infinite;
        }

        @keyframes scroll-anim {
            0% { transform: translateY(0); opacity: 1; }
            100% { transform: translateY(15px); opacity: 0; }
        }

        /* Navigation based on screenshot */
        .nav-pill {
            background: #ffffff;
            color: #007bff;
            padding: 0.5rem 1.5rem;
            border-radius: 50px;
        }

        /* Service Cards & Other sections maintained for consistency */
        .bg-services {
            background: linear-gradient(rgba(5,5,5,0.9), rgba(5,5,5,0.9)), 
                        url('https://images.unsplash.com/photo-1550751827-4bd374c3f58b?auto=format&fit=crop&q=80&w=2000');
            background-size: cover;
        }

        .form-input {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.4);
            padding: 1.25rem;
            width: 100%;
            outline: none;
            color: white;
        }

        .social-link {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 54px;
            height: 54px;
            border-radius: 50%;
            border: 1px solid rgba(255, 255, 255, 0.15);
            transition: all 0.3s ease;
            color: rgba(255, 255, 255, 0.6);
        }

        .social-link:hover {
            border-color: white;
            color: white;
            background: rgba(255, 255, 255, 0.1);
        }
    </style>
</head>
<body class="antialiased">

    <!-- Header / Navigation -->
