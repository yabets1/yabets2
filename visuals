        <div class="max-w-7xl mx-auto flex justify-between items-center">
            <div class="flex flex-col">
                <span class="text-3xl font-black tracking-tighter leading-none">YABETS</span>
                <span class="text-[9px] font-bold uppercase tracking-[0.2em] opacity-80">Support and Design</span>
            </div>
            <nav class="hidden lg:flex items-center gap-6 text-sm font-semibold">
