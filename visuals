        </div>
    </header>

    <!-- Hero Section -->
    <section class="hero-bg px-6">
        <h2 class="welcome-text">Welcome To YABETS</h2>
        <h1 class="main-headline">Web Support And Design</h1>
        <h3 class="services-headline">Our Services: <span class="typing-cursor"></span></h3>
        
        <div class="flex flex-wrap justify-center gap-4 mb-12">
            <a href="#contact" class="btn-white">Get started</a>
            <a href="#services" class="btn-grey">Learn More</a>
