    <!-- Services Section -->
    <section id="services" class="py-32 bg-services">
        <div class="max-w-6xl mx-auto px-6">
            <div class="mb-24 text-center">
                <h2 class="text-4xl md:text-6xl font-black mb-6 tracking-tight">SOLUTIONS</h2>
                <p class="text-gray-400 text-lg">Specialized digital engineering across multiple disciplines.</p>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="bg-white/5 backdrop-blur-md p-12 rounded-3xl border border-white/10 hover:border-white/30 transition-all group">
                    <i data-lucide="layout" class="text-white mb-8"></i>
                    <h3 class="text-2xl font-bold mb-6">Web Platforms</h3>
                    <p class="text-gray-400 leading-relaxed">High-end, scalable websites designed for conversions and performance.</p>
                </div>
                <div class="bg-white/5 backdrop-blur-md p-12 rounded-3xl border border-white/10 hover:border-white/30 transition-all">
                    <i data-lucide="message-square" class="text-white mb-8"></i>
                    <h3 class="text-2xl font-bold mb-6">AI Telegram Bots</h3>
                    <p class="text-gray-400 leading-relaxed">Intelligent automation that lives inside Telegram for your business.</p>
                </div>
                <div class="bg-white/5 backdrop-blur-md p-12 rounded-3xl border border-white/10 hover:border-white/30 transition-all">
                    <i data-lucide="code-2" class="text-white mb-8"></i>
                    <h3 class="text-2xl font-bold mb-6">Online Automation</h3>
                    <p class="text-gray-400 leading-relaxed">Scripting and API integrations for seamless digital operations.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="py-32 bg-zinc-900/50">
        <div class="max-w-6xl mx-auto px-6">
            <div class="text-center mb-16">
                <h2 class="text-5xl font-semibold mb-6">Contact Us</h2>
                <p class="text-gray-400 max-w-2xl mx-auto">
                    Just drop us a line and let us know what it is you need producing and we will reply to you as soon as possible.
                </p>
            </div>

            <form class="max-w-5xl mx-auto">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="flex flex-col gap-6">
                        <input type="text" placeholder="Your Name" class="form-input">
                        <input type="email" placeholder="Your Email" class="form-input">
                        <input type="tel" placeholder="Your Phone" class="form-input">
                    </div>
                    <div>
                        <textarea placeholder="Your Message" rows="8" class="form-input h-full resize-none"></textarea>
                    </div>
                </div>
                <div class="flex justify-center mt-12">
                    <button type="submit" class="bg-zinc-800 hover:bg-zinc-700 text-white px-12 py-4 rounded-full font-bold transition-all">
                        Send Message
                    </button>
                </div>
            </form>

            <!-- Social Links -->
            <div class="mt-24 text-center">
